# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Bắt buộc. Có thể đặt NHIỀU key, ngăn cách bằng dấu phẩy, để bật key rotation.
#   OPENAI_API_KEYS=sk-key-1,sk-key-2,sk-key-3
OPENAI_API_KEYS=sk-your-key-here

# Model dùng cho chat completions
LLM_MODEL=gpt-4o-mini

# ─── Generation params (mặc định, có thể override mỗi request) ────────────────
LLM_TEMPERATURE=0.2
LLM_MAX_COMPLETION_TOKENS=800
LLM_TOP_P=1.0

# ─── Resilience ──────────────────────────────────────────────────────────────
LLM_MAX_RETRIES=5

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=Vietnamese Legal Assistant
LOG_LEVEL=INFO
