# ─── Backend (Buổi 2: Local Serving) ─────────────────────────────────────────
# openai = OpenAI Cloud | ollama = Ollama local | vllm = vLLM server
LLM_BACKEND=openai
# Override base_url (để trống = dùng mặc định của backend):
#   ollama → http://localhost:11434/v1
#   vllm   → http://localhost:8000/v1
LLM_BASE_URL=

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Chỉ cần key thật khi LLM_BACKEND=openai. Backend local dùng key giả tự động.
# Có thể đặt NHIỀU key, ngăn cách bằng dấu phẩy, để bật key rotation.
#   OPENAI_API_KEYS=sk-key-1,sk-key-2,sk-key-3
OPENAI_API_KEYS=sk-your-key-here

# Model dùng cho chat completions.
#   openai → gpt-4o-mini
#   ollama → llama3.2:3b  hoặc  legal-assistant (tạo từ Modelfile)
LLM_MODEL=gpt-4o-mini

# ─── Generation params (mặc định, có thể override mỗi request) ────────────────
LLM_TEMPERATURE=0.2
LLM_MAX_COMPLETION_TOKENS=800
LLM_TOP_P=1.0

# ─── Resilience ──────────────────────────────────────────────────────────────
LLM_MAX_RETRIES=5

# ─── Embeddings & Vector Store (Buổi 4) ──────────────────────────────────────
# Embedding dùng OpenAI (cần OPENAI_API_KEYS ở trên, kể cả khi chat chạy local).
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# Qdrant: ":memory:" cho demo (không cần Docker). Production: http://localhost:6333
QDRANT_URL=:memory:
VECTORSTORE_COLLECTION=legal_docs

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=Vietnamese Legal Assistant
LOG_LEVEL=INFO
